{
  "name": "we-love-photos-app",
  "version": "2.0.0",
  "private": true,
  "description": "We Love Photos - Monorepo with pnpm and Turborepo",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "dev:web": "turbo dev --filter=@welovephotos/web",
    "dev:server": "turbo dev --filter=@welovephotos/server",
    "build:server": "turbo build --filter=@welovephotos/server"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "turbo": "^2.4.0"
  },
  "packageManager": "pnpm@11.5.1",
  "engines": {
    "node": ">=24.0.0"
  }
}